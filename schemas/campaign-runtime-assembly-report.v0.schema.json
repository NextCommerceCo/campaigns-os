{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nextcommerce.com/schemas/campaign-runtime-assembly-report.v0.schema.json",
  "title": "Campaigns OS Assembly Report v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "generated_at",
    "status",
    "identity",
    "inputs",
    "template_family",
    "stages",
    "decisions",
    "evidence",
    "blockers",
    "warnings",
    "next"
  ],
  "properties": {
    "schema_version": { "const": "campaign-runtime-assembly-report/v0" },
    "run_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "identity": {
      "type": "object",
      "additionalProperties": true,
      "required": ["map_id", "public_route_slug", "campaign_directory", "live_url_path", "spec_hash"],
      "properties": {
        "map_id": { "type": "string", "minLength": 1 },
        "public_route_slug": { "type": "string", "minLength": 1 },
        "campaign_directory": { "type": "string", "minLength": 1 },
        "live_url_path": { "type": "string", "minLength": 1 },
        "spec_hash": { "type": "string", "minLength": 1 }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": ["packet_path", "context_path", "spec_path", "source", "target_repo"],
      "properties": {
        "packet_path": { "type": "string", "minLength": 1 },
        "context_path": { "type": "string", "minLength": 1 },
        "spec_path": { "type": "string", "minLength": 1 },
        "source": {
          "type": "object",
          "required": ["kind", "root"],
          "properties": {
            "kind": { "enum": ["html_funnel", "figma_sections", "figma_freeform"] },
            "root": { "type": "string", "minLength": 1 }
          }
        },
        "target_repo": { "type": "string", "minLength": 1 }
      }
    },
    "template_family": {
      "type": "object",
      "additionalProperties": true,
      "required": ["value", "locked"],
      "properties": {
        "value": { "type": "string", "minLength": 1 },
        "locked": { "type": "boolean" },
        "locked_by": { "type": ["string", "null"] },
        "commerce_catalog_version": { "type": ["string", "null"] },
        "candidates": { "type": "array" }
      }
    },
    "stages": {
      "type": "object",
      "required": ["prepare_build", "doctor", "setup", "assembly", "polish", "deploy", "qa"],
      "properties": {
        "prepare_build": { "$ref": "#/$defs/stage" },
        "doctor": { "$ref": "#/$defs/stage" },
        "setup": { "$ref": "#/$defs/stage" },
        "assembly": { "$ref": "#/$defs/stage" },
        "polish": { "$ref": "#/$defs/stage" },
        "deploy": { "$ref": "#/$defs/stage" },
        "qa": { "$ref": "#/$defs/stage" }
      }
    },
    "checklists": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "polish": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "anchor_screenshots": {
              "type": "array",
              "items": { "$ref": "#/$defs/evidenceCheck" }
            },
            "state_screenshots": {
              "type": "array",
              "items": { "$ref": "#/$defs/evidenceCheck" }
            },
            "runtime_smoke": {
              "type": "array",
              "items": { "$ref": "#/$defs/evidenceCheck" }
            }
          }
        },
        "template_family": {
          "type": "object",
          "additionalProperties": true,
          "required": ["family", "invariants"],
          "properties": {
            "family": { "type": "string", "minLength": 1 },
            "invariants": {
              "type": "array",
              "items": { "$ref": "#/$defs/invariant" }
            }
          }
        }
      }
    },
    "decisions": { "type": "array" },
    "adapter_decisions": { "$ref": "#/$defs/adapterDecisions" },
    "proof_policy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "browser_qa_required": { "type": "boolean" },
        "typed_card_depth": { "type": "string", "minLength": 1 },
        "localhost_development_domain_allowed": { "type": "boolean" },
        "non_localhost_origin_allowlist_required": { "type": "boolean" },
        "order_path_depth": { "type": "string", "minLength": 1 },
        "operator_approval_state": { "type": "string", "minLength": 1 },
        "qa_portal_publish_default": { "type": "boolean" }
      }
    },
    "theme": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "status": { "enum": ["applied", "skipped", "blocked", "needs_review"] },
        "css_path": { "type": ["string", "null"] },
        "load_order": { "enum": ["after-next-core", "not-applied", "unknown"] },
        "commerce_pages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/themeIssue" }
        },
        "repair_loop_defect": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/themeIssue" }
          ]
        }
      }
    },
    "evidence": { "type": "array" },
    "blockers": { "type": "array" },
    "warnings": { "type": "array" },
    "next": {
      "type": "object",
      "additionalProperties": true,
      "required": ["stage", "owner", "action"],
      "properties": {
        "stage": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "blocked_stages": { "type": "array" }
      }
    }
  },
  "$defs": {
    "adapterDecisions": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "raw_html_conversion_status",
        "source_asset_strategy",
        "commerce_shell_adoption",
        "route_rewrite_policy",
        "template_files_copied",
        "config_script_strategy"
      ],
      "properties": {
        "raw_html_conversion_status": { "enum": ["pending", "in_progress", "completed", "not_required", "blocked"] },
        "source_asset_strategy": { "enum": ["pagekit_campaign_asset_root", "external_cdn", "raw_passthrough", "not_applicable", "unknown"] },
        "commerce_shell_adoption": { "enum": ["not_required", "template_clone_first_required", "template_clone_first_verified", "sdk_surfaces_preserved", "custom_html_experimental"] },
        "route_rewrite_policy": { "enum": ["campaignspec_routes_via_campaign_link", "pagekit_public_routes", "raw_passthrough", "not_applicable", "unknown"] },
        "config_script_strategy": { "enum": ["campaign_asset", "frontmatter_script", "inline", "not_required", "unknown"] },
        "template_files_copied": {
          "type": "object",
          "additionalProperties": true,
          "required": ["status", "required_groups", "groups", "paths"],
          "properties": {
            "status": { "enum": ["pending", "complete", "verified_existing_slice", "partial", "not_applicable"] },
            "required_groups": { "type": "array", "items": { "type": "string" } },
            "groups": { "type": "array", "items": { "type": "string" } },
            "paths": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": true,
      "required": ["stage", "status"],
      "properties": {
        "stage": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "inputs": { "type": "array", "default": [] },
        "outputs": { "type": "array", "default": [] },
        "commands": { "type": "array", "default": [] },
        "blockers": { "type": "array", "default": [] },
        "warnings": { "type": "array", "default": [] }
      }
    },
    "evidenceCheck": {
      "type": "object",
      "additionalProperties": true,
      "required": ["page_type", "evidence"],
      "properties": {
        "page_type": { "type": "string", "minLength": 1 },
        "anchor": { "type": "string" },
        "state": { "type": "string" },
        "viewports": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "status": { "type": "string" }
      }
    },
    "invariant": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "status", "evidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["passed", "failed", "blocked", "skipped"] },
        "evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": { "type": ["string", "null"] }
      }
    },
    "themeIssue": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "detail": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
