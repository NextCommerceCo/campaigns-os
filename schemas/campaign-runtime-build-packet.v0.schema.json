{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nextcommerce.com/schemas/campaign-runtime-build-packet.v0.schema.json",
  "title": "Campaigns OS Build Packet v0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "campaign", "spec", "source_html", "assembly", "deploy", "qa"],
  "properties": {
    "schema_version": {
      "const": "campaign-runtime-build-packet/v0"
    },
    "campaign": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public_route_slug", "api_key_source", "allowed_domains_confirmed"],
      "properties": {
        "public_route_slug": {
          "type": "string",
          "minLength": 1,
          "description": "Shopper-facing route slug, e.g. theduo-v3. It is often the same as the campaign directory, but the packet keeps them explicit."
        },
        "campaign_directory": {
          "type": ["string", "null"],
          "description": "Directory name inside the target repo for assembled campaign files, e.g. theduo-v3."
        },
        "live_url_path": {
          "type": ["string", "null"],
          "description": "Expected deployed path for this campaign, e.g. /theduo-v3/."
        },
        "campaigns_app_url": {
          "type": ["string", "null"]
        },
        "api_key_source": {
          "type": "string",
          "description": "Doctor-verifiable builds should use env:<VAR>. Use provided-out-of-band only for drafts."
        },
        "api_key": {
          "type": ["string", "null"],
          "description": "Direct/local value. Campaigns API keys are public-facing and domain-allowlisted, but env:<VAR> keeps examples and shared packets portable."
        },
        "allowed_domains_confirmed": {
          "type": "boolean"
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["map_id"],
      "properties": {
        "map_id": {
          "type": "string",
          "minLength": 1,
          "description": "Saved Map Builder identity used for reopen, /api/spec/<map-id>, QA verdicts, and provenance."
        },
        "spec_url": {
          "type": ["string", "null"]
        },
        "local_path": {
          "type": ["string", "null"]
        }
      },
      "anyOf": [
        { "required": ["spec_url"] },
        { "required": ["local_path"] }
      ]
    },
    "source_html": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "pages"],
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "pages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["page_id"],
            "properties": {
              "page_id": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "skip_reason": { "type": "string", "minLength": 1 },
              "notes": { "type": ["string", "null"] }
            },
            "anyOf": [
              { "required": ["path"] },
              { "required": ["skip_reason"] }
            ]
          }
        }
      }
    },
    "assembly": {
      "type": "object",
      "additionalProperties": false,
      "required": ["implementation", "target_repo", "output_dir", "template_family"],
      "properties": {
        "implementation": {
          "type": "string",
          "minLength": 1,
          "default": "next-campaigns-build"
        },
        "target_repo": {
          "type": "string",
          "minLength": 1
        },
        "output_dir": {
          "type": "string",
          "minLength": 1
        },
        "template_family": {
          "enum": [
            "undecided",
            "olympus",
            "limos",
            "demeter",
            "olympus-mv-single-step",
            "olympus-mv-two-step",
            "shop-single-step",
            "shop-three-step",
            "custom"
          ]
        },
        "template_decision_notes": {
          "type": ["string", "null"]
        },
        "template_lock": {
          "type": "object",
          "additionalProperties": false,
          "required": ["locked"],
          "properties": {
            "locked": {
              "type": "boolean",
              "description": "True only after an explicit operator/spec-confirmed template-family decision. A confidence score alone is not enough to lock commerce surfaces."
            },
            "locked_by": {
              "type": ["string", "null"],
              "description": "Who or what locked the family, e.g. operator_flag, operator_ack, spec_hint_ack."
            },
            "confidence": {
              "enum": ["none", "low", "medium", "high"]
            },
            "evidence": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "commerce_catalog": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required"],
          "properties": {
            "required": { "type": "boolean" },
            "family": { "type": ["string", "null"] },
            "version": { "type": ["string", "null"] },
            "path": { "type": ["string", "null"] }
          },
          "description": "Catalog gate for template-family checkout/payment/bundle/upsell/receipt surfaces."
        },
        "compatible_outputs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "deploy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target"],
      "properties": {
        "target": {
          "enum": ["netlify", "cloudflare-pages", "vercel", "shopify-proxy", "agency-ci", "unknown"]
        },
        "preview_url": {
          "type": ["string", "null"]
        },
        "production_url": {
          "type": ["string", "null"]
        },
        "live_url_path": {
          "type": ["string", "null"]
        }
      }
    },
    "qa": {
      "type": "object",
      "additionalProperties": false,
      "required": ["test_orders_allowed", "sandbox_test_card_confirmed"],
      "properties": {
        "test_orders_allowed": {
          "type": "boolean",
          "default": false
        },
        "sandbox_test_card_confirmed": {
          "type": "boolean",
          "default": false
        },
        "test_order_policy_notes": {
          "type": ["string", "null"]
        }
      }
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}
