{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nextcommerce.com/schemas/campaign-runtime-build-packet.v0.schema.json",
  "title": "Campaigns OS Build Packet v0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "campaign", "spec", "source_html", "assembly", "deploy", "qa"],
  "properties": {
    "schema_version": {
      "const": "campaign-runtime-build-packet/v0"
    },
    "campaign": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public_route_slug", "allowed_domains_confirmed"],
      "properties": {
        "public_route_slug": {
          "type": "string",
          "minLength": 1,
          "description": "Shopper-facing route slug, e.g. theduo-v3. It is often the same as the campaign directory, but the packet keeps them explicit."
        },
        "campaign_directory": {
          "type": ["string", "null"],
          "description": "Directory name inside the target repo for assembled campaign files, e.g. theduo-v3."
        },
        "live_url_path": {
          "type": ["string", "null"],
          "description": "Expected deployed path for this campaign, e.g. /theduo-v3/."
        },
        "campaigns_app_url": {
          "type": ["string", "null"]
        },
        "api_key_source": {
          "type": "string",
          "description": "Optional fallback source, usually env:<VAR>, when the local CampaignSpec does not carry campaign.campaigns_api_key."
        },
        "api_key": {
          "type": ["string", "null"],
          "description": "Legacy direct/local value. Prefer campaigns_api_key or the local CampaignSpec campaign.campaigns_api_key."
        },
        "campaigns_api_key": {
          "type": ["string", "null"],
          "description": "Direct/local Campaigns API key. Campaigns API keys are public-facing and domain-allowlisted; shared examples may still prefer spec or env sourcing."
        },
        "allowed_domains_confirmed": {
          "type": "boolean"
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["map_id"],
      "properties": {
        "map_id": {
          "type": "string",
          "minLength": 1,
          "description": "Saved Map Builder identity used for reopen, /api/spec/<map-id>, QA verdicts, and provenance."
        },
        "spec_url": {
          "type": ["string", "null"]
        },
        "local_path": {
          "type": ["string", "null"]
        }
      },
      "anyOf": [
        { "required": ["spec_url"] },
        { "required": ["local_path"] }
      ]
    },
    "source_html": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "pages"],
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "pages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["page_id"],
            "properties": {
              "page_id": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "page_type": { "type": "string", "minLength": 1 },
              "upsell_template_pattern": { "type": "string", "minLength": 1 },
              "upsell_mv_tiers": {
                "type": "object",
                "additionalProperties": false,
                "required": ["min", "max"],
                "properties": {
                  "min": { "type": "integer", "minimum": 1 },
                  "max": { "type": "integer", "minimum": 1 }
                }
              },
              "variant_labels": {
                "type": "object",
                "additionalProperties": false,
                "required": ["primary"],
                "properties": {
                  "primary": { "type": "string", "minLength": 1 },
                  "secondary": { "type": "string", "minLength": 1 }
                }
              },
              "source_hash": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$",
                "description": "Optional sha256 of the source HTML file at the time the manifest was written. Doctor compares this to the on-disk file's actual hash and warns on mismatch (Slice 6 drift detection)."
              },
              "skip_reason": { "type": "string", "minLength": 1 },
              "notes": { "type": ["string", "null"] }
            },
            "anyOf": [
              { "required": ["path"] },
              { "required": ["skip_reason"] }
            ]
          }
        },
        "adapter_contract": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "raw_html_conversion_status",
            "source_asset_strategy",
            "commerce_shell_adoption",
            "route_rewrite_policy",
            "template_files_copied",
            "config_script_strategy"
          ],
          "properties": {
            "raw_html_conversion_status": { "enum": ["pending", "in_progress", "completed", "not_required", "blocked"] },
            "source_asset_strategy": { "enum": ["pagekit_campaign_asset_root", "external_cdn", "raw_passthrough", "not_applicable", "unknown"] },
            "commerce_shell_adoption": { "enum": ["not_required", "template_clone_first_required", "template_clone_first_verified", "sdk_surfaces_preserved", "custom_html_experimental"] },
            "route_rewrite_policy": { "enum": ["campaignspec_routes_via_campaign_link", "pagekit_public_routes", "raw_passthrough", "not_applicable", "unknown"] },
            "config_script_strategy": { "enum": ["campaign_asset", "frontmatter_script", "inline", "not_required", "unknown"] },
            "template_files_copied": {
              "type": "object",
              "additionalProperties": true,
              "required": ["status", "required_groups", "groups", "paths"],
              "properties": {
                "status": { "enum": ["pending", "complete", "verified_existing_slice", "partial", "not_applicable"] },
                "required_groups": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "groups": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "paths": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "description": "Prepared HTML -> page-kit conversion contract. Build/report updates should move pending values to completed/verified once wrapper stripping, frontmatter, asset moves, CTA/routes, commerce shell, and template dependency copying are settled."
        }
      }
    },
    "assembly": {
      "type": "object",
      "additionalProperties": false,
      "required": ["implementation", "target_repo", "output_dir", "template_family"],
      "properties": {
        "implementation": {
          "type": "string",
          "minLength": 1,
          "default": "next-campaigns-build"
        },
        "target_repo": {
          "type": "string",
          "minLength": 1
        },
        "output_dir": {
          "type": "string",
          "minLength": 1
        },
        "template_family": {
          "enum": [
            "undecided",
            "olympus",
            "limos",
            "demeter",
            "olympus-mv-single-step",
            "olympus-mv-two-step",
            "shop-single-step",
            "shop-three-step",
            "custom"
          ]
        },
        "template_decision_notes": {
          "type": ["string", "null"]
        },
        "template_lock": {
          "type": "object",
          "additionalProperties": false,
          "required": ["locked"],
          "properties": {
            "locked": {
              "type": "boolean",
              "description": "True only after an explicit operator/spec-confirmed template-family decision. A confidence score alone is not enough to lock commerce surfaces."
            },
            "locked_by": {
              "type": ["string", "null"],
              "description": "Who or what locked the family, e.g. operator_flag, operator_ack, spec_hint_ack."
            },
            "confidence": {
              "enum": ["none", "low", "medium", "high"]
            },
            "evidence": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "commerce_catalog": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required"],
          "properties": {
            "required": { "type": "boolean" },
            "family": { "type": ["string", "null"] },
            "version": { "type": ["string", "null"] },
            "path": { "type": ["string", "null"] }
          },
          "description": "Catalog gate for template-family checkout/payment/bundle/upsell/receipt surfaces."
        },
        "compatible_outputs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "deploy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target"],
      "properties": {
        "target": {
          "enum": ["netlify", "cloudflare-pages", "vercel", "shopify-proxy", "agency-ci", "unknown"]
        },
        "preview_url": {
          "type": ["string", "null"]
        },
        "production_url": {
          "type": ["string", "null"]
        },
        "live_url_path": {
          "type": ["string", "null"]
        }
      }
    },
    "qa": {
      "type": "object",
      "additionalProperties": false,
      "required": ["test_orders_allowed", "sandbox_test_card_confirmed"],
      "properties": {
        "test_orders_allowed": {
          "type": "boolean",
          "default": false
        },
        "sandbox_test_card_confirmed": {
          "type": "boolean",
          "default": false
        },
        "proof_policy": {
          "type": "object",
          "additionalProperties": true,
          "required": ["browser_qa_required", "typed_card_depth", "localhost_development_domain_allowed", "non_localhost_origin_allowlist_required", "order_path_depth", "operator_approval_state"],
          "properties": {
            "browser_qa_required": { "type": "boolean" },
            "typed_card_depth": { "type": "string", "minLength": 1 },
            "localhost_development_domain_allowed": { "type": "boolean" },
            "non_localhost_origin_allowlist_required": { "type": "boolean" },
            "order_path_depth": { "type": "string", "minLength": 1 },
            "operator_approval_state": { "type": "string", "minLength": 1 },
            "qa_portal_publish_default": { "type": "boolean" }
          }
        },
        "test_order_policy_notes": {
          "type": ["string", "null"]
        }
      }
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}
