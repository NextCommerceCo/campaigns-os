{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nextcommerce.com/schemas/campaign-runtime-build-context.v0.schema.json",
  "title": "Campaigns OS Build Context v0",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "source_adapter", "status", "spec", "source", "page_map", "scaffold", "template", "prompts_required"],
  "properties": {
    "schema_version": { "const": "campaign-runtime-build-context/v0" },
    "generated_at": { "type": "string" },
    "source_adapter": { "enum": ["html_funnel", "figma_sections"] },
    "status": { "enum": ["prepared", "blocked"] },
    "packet_path": { "type": "string" },
    "report_path": { "type": "string" },
    "spec": {
      "type": "object",
      "required": ["path", "hash", "active_pages"],
      "properties": {
        "path": { "type": "string" },
        "hash": { "type": "string" },
        "active_pages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "type": { "type": ["string", "null"] },
              "label": { "type": ["string", "null"] },
              "page_url": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "source": {
      "type": "object",
      "properties": {
        "root": { "type": "string" },
        "html_files": { "type": "array" },
        "figma_manifest": { "type": ["object", "null"] },
        "asset_crawl": {
          "type": "object",
          "additionalProperties": true,
          "required": ["schema_version", "scanned_files", "references", "summary", "warnings"],
          "properties": {
            "schema_version": { "const": "source-asset-crawl/v0" },
            "scanned_files": { "type": "array" },
            "references": { "type": "array" },
            "summary": { "type": "object", "additionalProperties": true },
            "warnings": { "type": "array" }
          }
        }
      }
    },
    "build_brief": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema_version", "mode", "status", "normalized_path", "question_count", "gate_count"],
      "properties": {
        "schema_version": { "const": "campaigns-os-build-brief/v1" },
        "mode": { "enum": ["prepared", "guided_draft"] },
        "status": { "enum": ["complete", "needs_answers", "invalid"] },
        "input_path": { "type": ["string", "null"] },
        "normalized_path": { "type": "string", "minLength": 1 },
        "question_count": { "type": "integer", "minimum": 0 },
        "gate_count": { "type": "integer", "minimum": 0 },
        "questions": { "type": "array" },
        "gates": { "type": "array" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "needs_answers" } },
            "required": ["status"]
          },
          "then": {
            "anyOf": [
              {
                "properties": {
                  "question_count": { "type": "integer", "minimum": 1 }
                }
              },
              {
                "properties": {
                  "gate_count": { "type": "integer", "minimum": 1 }
                }
              }
            ]
          }
        }
      ],
      "description": "Campaign Build Brief handoff summary. The normalized full artifact lives at normalized_path."
    },
    "page_map": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["page_id"],
        "properties": {
          "page_id": { "type": "string" },
          "source_path": { "type": ["string", "null"] },
          "skip_reason": { "type": ["string", "null"] },
          "output_path": {
            "type": ["string", "null"],
            "description": "Page Kit target file path relative to the target repo. This mirrors page_kit.output_path; source_path remains producer provenance."
          },
          "page_kit": {
            "type": ["object", "null"],
            "properties": {
              "target_path": { "type": "string", "minLength": 1 },
              "output_path": {
                "type": "string",
                "minLength": 1,
                "description": "Page Kit target file path relative to the target repo."
              },
              "public_route": { "type": "string", "minLength": 1 },
              "spec_route": { "type": "string" },
              "page_type": {
                "enum": ["product", "checkout", "upsell", "receipt"],
                "description": "Page Kit runtime/analytics page_type. Producer or CampaignSpec page types may use richer vocabulary upstream."
              },
              "permalink_required": { "type": "boolean", "default": false },
              "frontmatter": {
                "type": "object",
                "additionalProperties": false,
                "required": ["page_type"],
                "properties": {
                  "page_type": {
                    "enum": ["product", "checkout", "upsell", "receipt"],
                    "description": "Page Kit runtime/analytics page_type. This is authoritative for generated frontmatter and may differ from source or producer page types."
                  },
                  "permalink": { "type": "string", "minLength": 1 },
                  "next_url": { "type": "string", "minLength": 1 },
                  "decline_url": { "type": "string", "minLength": 1 }
                }
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": { "permalink_required": { "const": true } },
                  "required": ["permalink_required"]
                },
                "then": {
                  "required": ["frontmatter"],
                  "properties": {
                    "frontmatter": {
                      "required": ["permalink"]
                    }
                  }
                }
              }
            ]
          }
        }
      }
    },
    "scaffold": {
      "type": "object",
      "required": ["mode", "required", "target_repo", "output_dir", "handoff_skill", "handoff_artifact"],
      "properties": {
        "mode": { "enum": ["fresh", "existing", "blocked"] },
        "required": { "type": "boolean" },
        "target_repo": { "type": "string" },
        "output_dir": { "type": "string" },
        "handoff_skill": { "type": "string" },
        "handoff_artifact": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "template": {
      "type": "object",
      "required": ["family", "locked"],
      "properties": {
        "family": { "type": "string" },
        "locked": { "type": "boolean" },
        "lock": { "type": "object" },
        "candidates": { "type": "array" }
      }
    },
    "theme": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "policy", "source_kind", "confidence", "generated"],
      "properties": {
        "status": { "enum": ["ready", "ready_with_warnings", "missing", "blocked", "disabled"] },
        "policy": { "enum": ["inspect_only", "auto", "off"] },
        "source_kind": { "const": "html_funnel" },
        "producer": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "name": { "type": "string" },
            "version": { "type": "string" }
          }
        },
        "source_files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["path", "role", "hash"],
            "properties": {
              "path": { "type": "string" },
              "role": { "type": "string" },
              "hash": { "type": "string" },
              "token_count": { "type": "number" }
            }
          }
        },
        "selected_source": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "producer_defaults": {
          "type": "object",
          "additionalProperties": true
        },
        "confidence": { "enum": ["high", "medium", "low", "none"] },
        "generated": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "css_path": { "type": ["string", "null"] },
            "report_path": { "type": ["string", "null"] },
            "can_generate": { "type": "boolean" },
            "can_auto_generate": { "type": "boolean" },
            "overwrite_requires_force": { "type": "boolean" },
            "safety": {
              "type": "object",
              "additionalProperties": false,
              "required": ["ok", "errors", "warnings"],
              "properties": {
                "ok": { "type": "boolean" },
                "errors": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/themeIssue" }
                },
                "warnings": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/themeIssue" }
                }
              }
            },
            "stale": {
              "type": "object",
              "additionalProperties": false,
              "required": ["stale", "reasons"],
              "properties": {
                "stale": { "type": "boolean" },
                "reasons": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        },
        "mappings": { "type": "array" },
        "unmapped_defaults": { "type": "array" },
        "warnings": { "type": "array" }
      }
    },
    "commerce_zone_findings": { "type": "array" },
    "adapter_decisions": { "$ref": "#/$defs/adapterDecisions" },
    "prompts_required": { "type": "array" },
    "decisions": { "type": "array" }
  },
  "$defs": {
    "adapterDecisions": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "raw_html_conversion_status",
        "source_asset_strategy",
        "commerce_shell_adoption",
        "route_rewrite_policy",
        "template_files_copied",
        "config_script_strategy",
        "wrapper_policy",
        "frontmatter_policy",
        "script_style_reference_policy",
        "cta_rewrite_policy",
        "layout_choice"
      ],
      "properties": {
        "raw_html_conversion_status": { "enum": ["pending", "in_progress", "completed", "not_required", "blocked"] },
        "source_asset_strategy": { "enum": ["pagekit_campaign_asset_root", "external_cdn", "raw_passthrough", "not_applicable", "unknown"] },
        "commerce_shell_adoption": { "enum": ["not_required", "template_clone_first_required", "template_clone_first_verified", "sdk_surfaces_preserved", "custom_html_experimental"] },
        "route_rewrite_policy": { "enum": ["campaignspec_routes_via_campaign_link", "pagekit_public_routes", "raw_passthrough", "not_applicable", "unknown"] },
        "config_script_strategy": { "enum": ["campaign_asset", "frontmatter_script", "inline", "not_required", "unknown"] },
        "wrapper_policy": { "enum": ["strip_document_wrappers", "preserve_document_wrappers", "not_required", "unknown"] },
        "frontmatter_policy": { "enum": ["pagekit_yaml_frontmatter", "raw_passthrough", "not_required", "unknown"] },
        "script_style_reference_policy": { "enum": ["frontmatter_or_campaign_asset", "frontmatter", "campaign_asset", "inline", "raw_passthrough", "not_required", "unknown"] },
        "cta_rewrite_policy": { "enum": ["campaignspec_routes_via_campaign_link", "pagekit_public_routes", "raw_passthrough", "not_applicable", "unknown"] },
        "layout_choice": { "enum": ["campaign_layout", "page_layout", "raw_passthrough", "not_applicable", "unknown"] },
        "template_files_copied": {
          "type": "object",
          "additionalProperties": true,
          "required": ["status", "required_groups", "groups", "paths"],
          "properties": {
            "status": { "enum": ["pending", "complete", "verified_existing_slice", "partial", "not_applicable"] },
            "required_groups": { "type": "array", "items": { "type": "string" } },
            "groups": { "type": "array", "items": { "type": "string" } },
            "paths": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "themeIssue": {
      "type": "object",
      "additionalProperties": true,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "detail": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
