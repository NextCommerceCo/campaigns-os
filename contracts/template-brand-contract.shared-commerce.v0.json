{
  "schema_version": "template-brand-contract/v0",
  "description": "Shared brand, residue, pricing, and offer-surface rules for starter-template commerce families that consume next-core.css brand tokens.",
  "brand_tokens": {
    "consumed_namespace": "--brand--*",
    "required_overrides": [
      "--brand--color--primary",
      "--brand--color--primary-dark"
    ],
    "recommended_overrides": [
      "--brand--color--cta-primary",
      "--brand--color--primary-light",
      "--brand--color--primary-lighter",
      "--brand--color--rating-star"
    ],
    "forbidden_default_values": {
      "--brand--color--primary": "#3c7dff",
      "--brand--color--primary-dark": "#0a265c"
    },
    "note": "Starter commerce pages consume --brand--* tokens from next-core.css. Campaign-namespace tokens style custom source markup only; they never restyle SDK commerce surfaces unless mapped into --brand--* overrides."
  },
  "css_load_order": {
    "core_stylesheet": "next-core.css",
    "brand_layer": "brand-theme.css",
    "rule": "brand_layer_after_core",
    "applies_to_page_types": ["checkout", "select", "upsell", "downsell", "receipt"]
  },
  "default_residue": {
    "logo": {
      "asset": "images/next-logo.png",
      "selector": "img.brand-logo",
      "page_types": ["checkout", "select", "upsell", "downsell", "receipt"],
      "rule": "Campaign brand logo must replace the starter next-logo.png on commerce pages unless the CampaignSpec store branding intentionally keeps it."
    },
    "payment_chrome": {
      "methods": ["paypal", "klarna"],
      "selectors": [
        ".payment-method__icon--paypal-logo",
        ".payment-method__icon--paypal-txt",
        ".payment-method__icon--klarna-logo"
      ],
      "assets": [
        "images/paypal.svg",
        "images/paypal-logo.svg",
        "images/paypal-txt.svg",
        "images/klarna-logo.svg",
        "images/upsell-payment-logos.svg"
      ],
      "rule": "Remove unless the method is listed in CampaignSpec available_payment_methods / available_express_payment_methods. Template chrome outside the SDK payment-method include counts as implied payment-method residue.",
      "note": "paypal intentionally has two selectors. QA fails if any selector for an unsupported method remains visible."
    }
  },
  "qa_inspection": {
    "forbidden_computed_colors": [
      { "hex": "#3c7dff", "rgb": "rgb(60, 125, 255)", "token": "--brand--color--primary" },
      { "hex": "#0a265c", "rgb": "rgb(10, 38, 92)", "token": "--brand--color--primary-dark" }
    ],
    "computed_style_checks": [
      {
        "id": "checkout_submit_button",
        "page_types": ["checkout"],
        "selector": ".submit-button",
        "properties": ["background-color", "border-color"],
        "optional": false
      },
      {
        "id": "selected_bundle_card",
        "page_types": ["checkout", "select"],
        "selector": ".os-card.next-selected",
        "properties": ["border-color", "outline-color"],
        "optional": true
      },
      {
        "id": "announcement_bar",
        "page_types": ["checkout", "upsell", "downsell"],
        "selector": ".announcement",
        "properties": ["background-color"],
        "optional": true
      },
      {
        "id": "bump_outline",
        "page_types": ["checkout"],
        "selector": "[data-next-package-sync='false'], .bump-offer, .order-bump",
        "properties": ["border-color", "outline-color"],
        "optional": true
      },
      {
        "id": "upsell_accept_cta",
        "page_types": ["upsell", "downsell"],
        "selector": "[data-next-action='accept'], [data-next-upsell-action='add'], a[href*='upsell-accept'], .submit-button",
        "properties": ["background-color"],
        "optional": false
      }
    ]
  },
  "pricing_surfaces": {
    "modes": ["full_price", "compare_at_current", "unit_price_plus_total", "savings_badge_amount", "code_discounted_post_checkout"],
    "legacy_aliases": {
      "discounted": "compare_at_current",
      "compare_at": "compare_at_current",
      "unit_total": "unit_price_plus_total",
      "unit_only": "full_price"
    },
    "rule": "Pricing surfaces render via mode-driven partial arguments, never via campaign CSS that hides price rows. Campaign stylesheets must not apply display:none to price wrappers or SDK price displays.",
    "same_price_strike_rule": "If no offer, voucher, compare-at value, or code-discounted post-checkout state governs an order bump, upsell, or downsell, render full_price only; do not show identical struck-through and current prices.",
    "forbidden_css_hides": [
      ".price-wrapper",
      ".prices-text-wrapper",
      ".price-display",
      ".cart-price",
      ".summary_price",
      "[data-next-display*='price']"
    ],
    "surfaces": {
      "checkout_bundle": {
        "default_mode": "compare_at_current",
        "price_row_selectors": [".price-wrapper", ".cart-price", "[data-next-bundle-display*='price']", "[data-next-display*='price']"]
      },
      "bump": {
        "default_mode": "full_price",
        "price_row_selectors": [".price-wrapper", ".cart-price", "[data-next-display*='price']"]
      },
      "upsell": {
        "default_mode": "full_price",
        "price_row_selectors": [".price-wrapper", ".price-display", ".summary_price", "[data-next-display*='price']"],
        "visible_price_rows_by_mode": {
          "full_price": 1,
          "compare_at_current": 2,
          "unit_price_plus_total": 2,
          "savings_badge_amount": 2,
          "code_discounted_post_checkout": 2
        },
        "note": "A full_price upsell shows exactly one visible price row adjacent to the accept control. Zero visible price rows on an upsell/downsell offer is a blocker."
      }
    }
  },
  "exit_pop": {
    "requires_spec_surface": ["exit_intent", "promo_code_input"],
    "residue_literals": [
      "exit-intent-popup",
      "data-template=\"exit-intent\"",
      "data-exit-intent-action",
      "data-coupon-code=\"EXIT5\"",
      "data-coupon-code=\"EXIT10\"",
      "data-coupon-code=\"SAVE10\""
    ],
    "blank_widget_literals": [
      "data-coupon-code=\"\"",
      "Apply My Discount Coupon"
    ],
    "rule": "If an exit-intent include or default widget ships without CampaignSpec checkout exit_intent or promo_code_input behavior, strip it or record a hard warning. If present, it must apply the mapped offer through the SDK/API coupon path and use cart.hasCoupon(\"CODE\") style conditionals for applied-state presentation."
  }
}
