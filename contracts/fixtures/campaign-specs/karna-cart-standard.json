          }
        },
        {
          "id": "receipt",
          "type": "thankyou",
          "order": 3,
          "label": "Receipt",
          "template": "src/karna/receipt.html",
          "page_url": "/receipt/",
          "sdk_hints": {
            "template_family": "karna",
            "frontmatter": {
              "receipt_summary.title": "Order Summary"
            }
          }
        }
      ]
    }
