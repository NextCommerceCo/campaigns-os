{
  "schema_version": "brand-theme-target-tokens/v0",
  "target": "next-core",
  "target_version": "v0",
  "description": "Shared root custom-property target surface for Campaigns OS brand-theme.css generation. V0 generation must emit only these :root variables.",
  "tokens": [
    "--brand--color--primary",
    "--brand--color--primary-dark",
    "--brand--color--primary-light",
    "--brand--color--primary-lighter",
    "--brand--color--cta-primary",
    "--brand--color--accent",
    "--brand--color--secondary",
    "--brand--color--background",
    "--brand--color--surface",
    "--brand--color--foreground",
    "--brand--color--text-primary",
    "--brand--color--text-secondary",
    "--brand--color--text-inverse",
    "--brand--color--border",
    "--system-colors--success",
    "--system-colors--destructive"
  ],
  "source_mappings": {
    "--brand-primary": ["--brand--color--primary"],
    "--brand-accent": ["--brand--color--accent"],
    "--brand-secondary": ["--brand--color--secondary"],
    "--surface-bg": ["--brand--color--background"],
    "--surface-card": ["--brand--color--surface"],
    "--text-primary": ["--brand--color--text-primary", "--brand--color--foreground"],
    "--text-secondary": ["--brand--color--text-secondary"],
    "--text-inverse": ["--brand--color--text-inverse"],
    "--border-default": ["--brand--color--border"],
    "--state-success": ["--system-colors--success"],
    "--ui-success": ["--system-colors--success"],
    "--state-error": ["--system-colors--destructive"],
    "--ui-danger": ["--system-colors--destructive"],
    "--brand-cta": ["--brand--color--cta-primary"],
    "--cta-primary": ["--brand--color--cta-primary"],
    "--button-primary-bg": ["--brand--color--cta-primary"]
  },
  "derived_mappings": {
    "--brand-primary": {
      "--brand--color--primary-dark": { "method": "mix-black", "amount": 0.18 },
      "--brand--color--primary-light": { "method": "mix-white", "amount": 0.2 },
      "--brand--color--primary-lighter": { "method": "mix-white", "amount": 0.86 }
    }
  }
}
