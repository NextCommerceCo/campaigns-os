            {
              "ref_id": 1,
              "name": "Upsell offer",
              "price": 29.99,
              "price_retail": 39.99
            }
          ]
        },
        {
          "id": "thankyou",
          "type": "thankyou",
          "label": "Thank You"
        }
      ]
    }
  ],
  "analytics": {
    "mode": "auto",
    "providers": {
      "gtm": {
        "enabled": true,
        "containerId": "GTM-EXAMPLE1"
      }
    },
    "manual_events": [
      {
        "event": "dl_purchase",
        "page": "upsell-1",
        "trigger": "page-load"
      }
    ]
  }
