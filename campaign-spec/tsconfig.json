{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "types": ["bun-types"]
  },
  "include": ["*.ts", "rules/*.ts", "fixtures/*.ts", "test/**/*.ts"]
}
