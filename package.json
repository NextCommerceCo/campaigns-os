{
  "name": "@nextcommerce/campaigns-os",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Toolkit for agent-assisted NEXT campaign builds.",
  "type": "module",
  "bin": {
    "campaigns-os": "./bin/campaigns-os.mjs"
  },
  "scripts": {
    "campaigns-os": "node ./bin/campaigns-os.mjs",
    "skills": "bash ./skills.sh",
    "qa": "node ./bin/campaigns-os.mjs qa",
    "qa:install-browser": "npx playwright install chromium",
    "refresh:starter-catalog": "node ./scripts/refresh-starter-template-catalog.mjs",
    "check": "node --test ./src/qa-browser.test.mjs ./src/qa-verdict.test.mjs ./src/qa-publish.test.mjs ./src/findings.test.mjs ./src/doctor-demo-ref.test.mjs ./src/doctor-built-output.test.mjs ./src/doctor-commerce-shell.test.mjs ./src/doctor-template-contract.test.mjs ./src/doctor-store-profile.test.mjs ./src/brand-theme.test.mjs ./scripts/refresh-starter-template-catalog.test.mjs && node ./scripts/check-fixtures.mjs && node ./scripts/check-private-strings.mjs && node ./scripts/check-template-doctrine.mjs && node ./scripts/check-cart-readiness-contract.mjs",
    "check:fixtures": "node ./scripts/check-fixtures.mjs",
    "check:private-strings": "node ./scripts/check-private-strings.mjs",
    "check:template-doctrine": "node ./scripts/check-template-doctrine.mjs",
    "check:cart-readiness": "node ./scripts/check-cart-readiness-contract.mjs"
  },
  "engines": {
    "node": ">=23.6.0"
  },
  "dependencies": {
    "playwright": "^1.60.0"
  },
  "files": [
    "agents",
    "bin",
    "campaign-spec",
    "contracts",
    "docs",
    "examples",
    "prompts",
    "schemas",
    "scripts",
    "skills.sh",
    "skills",
    "src",
    "README.md",
    "compatibility.json"
  ]
}
